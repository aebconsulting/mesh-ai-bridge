# mesh-ai-bridge configuration — copy to your deployment as environment variables.
# Only the radio connection and an LLM endpoint are required; the rest degrade gracefully.

# ---- Radio (choose serial OR tcp) ----
# TCP mode: set the host of a ser2net / meshtasticd endpoint exposing the radio.
MESH_TCP_HOST=
MESH_TCP_PORT=4403
# Serial mode: used when MESH_TCP_HOST is empty. Path to the radio's serial device.
MESH_SERIAL=/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_0001-if00-port0

# ---- LLM (required) — any OpenAI-compatible /v1/chat/completions endpoint ----
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=deepseek-r1:8b
LLM_MAX_TOKENS=600
LLM_TIMEOUT_S=120

# ---- Behavior ----
TRIGGER_PREFIX=@ai
ALLOWED_CHANNELS=0
# Node IDs allowed to teach facts via "@ai remember ...", comma-separated (e.g. !abcd1234,!1122eeff)
ADMIN_NODES=
SYSTEM_PROMPT=You are NOMAD, an off-grid AI assistant reached over a LoRa mesh radio network. Replies must be plain text, no markdown, and under 300 characters total. Be direct and useful; brevity is life-or-death bandwidth here.

# ---- LoRa reply sizing ----
CHUNK_BYTES=190
MAX_REPLY_CHUNKS=2

# ---- Rate limiting ----
NODE_COOLDOWN_S=30
GLOBAL_PER_MIN=6

# ---- Memory / logging (SQLite) ----
MEM_DB=/opt/mesh-ai-bridge/memory.db
HISTORY_TURNS=6
FACTS_MAX=20
MSG_LOG_RETENTION_DAYS=90

# ---- Semantic retrieval (optional; needs an embeddings endpoint + a qdrant collection) ----
# Embeddings use Ollama's native /api/embeddings.
EMBED_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=knowledge_base
QDRANT_TOP_K=8
QDRANT_MIN_SCORE=0.65
QDRANT_TIMEOUT_S=10
EMBED_TIMEOUT_S=15
MIN_CHUNK_CHARS=120
# Reserved hook for a future cross-encoder rerank stage; not wired in this release (leave off).
RERANK_ENABLED=false

# ---- Offline library keyword fallback (optional; used when embed/qdrant are down) ----
KIWIX_URL=http://127.0.0.1:8090
# Comma-separated Kiwix book names to prioritize (empty = all available)
LIBRARY_BOOKS=
LIBRARY_MAX_BOOKS=3
LIBRARY_CONTEXT_CHARS=2500

# ---- Dashboard send API (optional; disabled unless SEND_TOKEN is set) ----
# Generate: openssl rand -hex 24  — bind SEND_PORT to a PRIVATE network only.
SEND_TOKEN=
SEND_PORT=8700
SEND_PER_MIN=6
SEND_COOLDOWN_S=5

# ---- Queue ----
QUEUE_MAX=100
DEDUP_TTL_S=120

# ---- v7: mesh weather telemetry (zero-config; on automatically) ----
# Nodes with BME280/680 sensors broadcast temp/humidity/pressure; the bridge aggregates
# fresh readings into the AI context. Nothing to enable — no sensors just means no data.
ENV_WINDOW_S=3600
ENV_TEMP_UNIT=F

# ---- v8: internet backup for live-data queries (optional; default OFF) ----
# When the host happens to be online, weather/live-data questions are answered with real
# current conditions (keyless APIs: Open-Meteo, zippopotam.us, BigDataCloud reverse-geocode).
# Location resolution: place named in the query > the asking node's GPS > the bridge node's
# GPS > NET_DEFAULT_PLACE. Offline, behavior is identical to v7 (honest "no live data").
NET_BACKUP=false
NET_TIMEOUT_S=6
NET_PROBE_TTL_S=60
NET_CACHE_TTL_S=600
NET_DEFAULT_PLACE=

# ---- v8: general live web search (optional; needs a SearXNG instance with format=json) ----
# Explicit "search <query>" always searches; news/price/score/"latest"-shaped queries search
# automatically. Empty SEARX_URL disables. Gated by NET_BACKUP + the connectivity probe.
SEARX_URL=
SEARCH_RESULTS=4
